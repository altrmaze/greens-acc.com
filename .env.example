# Greens ACC — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real credentials.

# ── Supabase ───────────────────────────────────────────────────────────────
# Project URL — found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anonymous (public) key — safe to expose to the browser.
# Found in: Supabase Dashboard → Settings → API → Project API keys
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Developer gate (optional) ──────────────────────────────────────────────
# When set, the /command-center, /rooms, and /analytics routes require
# this token to be entered before the page loads. Leave blank to disable.
VITE_DEV_GATE_TOKEN=

# ── Test users (CI only, never for production) ─────────────────────────────
# Used by automated tests to verify auth flows.
# Set via GitHub Actions secrets — do not add real values here.
VITE_TEST_USER_EMAIL=
VITE_TEST_USER_PASSWORD=
