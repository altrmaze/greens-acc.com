# =============================================================================
# Greens ACC — Environment Variable Reference
# =============================================================================
# Copy this file to .env for local development.
# NEVER commit a filled-in .env to source control — it is already in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend Client Access  (safe for browser exposure)
# Set these on your static-site host or inject via window.__ENV__ at runtime.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key-here"

# -----------------------------------------------------------------------------
# Backend / Edge Function Runtime  (NEVER expose to the browser)
# Set these as Supabase Function secrets:
#   supabase secrets set SUPABASE_URL="..." SUPABASE_SERVICE_ROLE_KEY="..."
# -----------------------------------------------------------------------------
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-high-privilege-service-role-key-here"

# -----------------------------------------------------------------------------
# CLI & Deployment Automation
# Add these as GitHub Actions secrets (Settings → Secrets → Actions).
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_ACCESS_TOKEN="your-personal-cli-access-token"

# -----------------------------------------------------------------------------
# Database (required only when running `supabase db push`)
# -----------------------------------------------------------------------------
PRODUCTION_DB_PASSWORD="your-database-password-here"

# -----------------------------------------------------------------------------
# Stripe (required for payment edge functions)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-signing-secret"

# -----------------------------------------------------------------------------
# Python integration server (backend/server.py)
# -----------------------------------------------------------------------------
SUPABASE_FUNCTIONS_BASE_URL="https://your-project-id.supabase.co/functions/v1"
PORT=5000
